name = "my-shopify-worker"
main = "shopify-worker.js"
compatibility_date = "2024-10-01"

[vars]
# Your Shopify store subdomain — just "my-store", not "my-store.myshopify.com"
SHOPIFY_STORE = "my-store"

# Comma-separated list of browser origins allowed to call this worker.
# Add your app's domain. localhost and *.workers.dev are always allowed.
ALLOWED_ORIGINS = "https://your-app.com,https://your-app.pages.dev"

# Optional: contact email used in Lulu print job submissions
# LULU_CONTACT_EMAIL = "orders@your-store.com"

# ── Secrets ────────────────────────────────────────────────────────────────────
# DO NOT put secret values here. Set them via:
#   wrangler secret put SHOPIFY_CLIENT_ID
#   wrangler secret put SHOPIFY_CLIENT_SECRET
#   wrangler secret put WORKER_SECRET
#   wrangler secret put ANTHROPIC_API_KEY      (optional)
#   wrangler secret put LULU_CLIENT_KEY        (optional)
#   wrangler secret put LULU_CLIENT_SECRET     (optional)
